{
    "name": "psc-acme/client-order",
    "description": "Package client-order for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ClientOrder\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "doctrine/doctrine-bundle": "^2.13",
        "symfony/messenger": "^7.0",
        "symfony/serializer": "^7.0",
        "symfony/string": "^7.0",
        "symfony/finder": "^7.0",
        "psc-acme/provider-billing": "^1.0",
        "psc-acme/worker-invoice": "^1.0",
        "psc-acme/sanitizer-invoice": "^1.0"
    },
    "require-dev": {
        "infection/infection": "^0.27",
        "fakerphp/faker": "^1.0",
        "vimeo/psalm": "^5.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}